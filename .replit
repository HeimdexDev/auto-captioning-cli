run = "python3 web/server.py"

modules = ["python-3.12"]

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Serve viewer"

[[workflows.workflow]]
name = "Serve viewer"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 web/server.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
